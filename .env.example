# Ultra PDF Editor - Environment Configuration
# Copy this file to .env and fill in your values
# Run with: uv run --env-file .env Ultra_PDF_Editor.py

# OCR - path to tesseract binary (leave blank to use system PATH)
TESSERACT_CMD=
OCR_LANGUAGE=eng

# Rendering
RENDER_DPI=150
HIGH_QUALITY_DPI=300

# Debug
DEBUG=false
LOG_LEVEL=INFO
